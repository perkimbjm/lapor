rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // CMS Content - Publicly readable, only admins can write
    match /cms/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications - Only admin can read/write
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Complaints - Publicly readable, only admins can write
    match /complaints/{complaintId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Materials - Only admin can read/write
    match /materials/{materialId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Equipment - Only admin can read/write
    match /equipment/{equipmentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Workforce - Only admin can read/write
    match /workforce/{workforceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Reports - Only admin can read/write
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // CostReports - Only admin can read/write
    match /costReports/{costReportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Users collection - Only owner or admin can read/write
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}
